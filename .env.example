# =============================================================================
# BTC ML Trading Bot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# Application
APP_ENV=development
LOG_LEVEL=INFO

# Binance (public endpoints only in v1)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# CoinGecko
COINGECKO_API_KEY=

# MLflow tracking (optional, for future use)
MLFLOW_TRACKING_URI=http://localhost:5000
